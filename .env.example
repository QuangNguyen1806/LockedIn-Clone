# Database (defaults use services/api/lockedin.db via app config)
# DATABASE_URL=
# DATABASE_URL_SYNC=

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost

# AI providers
LLM_PROVIDER=gemini
STT_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_STT_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
USE_MOCK_AI=true

# Storage
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=10

# Worker
REDIS_URL=redis://localhost:6379/0
WORKER_POLL_INTERVAL=5

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Desktop
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
